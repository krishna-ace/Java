interface Animal {
    void animalSound();
    void sleep();
}

class Pig implements Animal {

    @Override
    public void animalSound() {
        System.out.println("Pig says: wee wee");
    }

    @Override
    public void sleep() {
        System.out.println("Zzz...");
    }
}

public class Main {
    public static void main(String[] args) {

        // Interface reference (best practice)
        Animal myPig = new Pig();

        myPig.animalSound();
        myPig.sleep();
    }
}
