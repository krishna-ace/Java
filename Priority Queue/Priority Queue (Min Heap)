import java.util.*;

public class Main {
    public static void main(String[] args) {
        PriorityQueue<Integer> pq = new PriorityQueue<>();
        pq.add(50);
        pq.add(10);
        pq.add(30);

        while (!pq.isEmpty()) {
            System.out.print(pq.poll() + " ");
        }
    }
}
